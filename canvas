# ---------- interactive ----------
build_model; layout; build_offmap

raw_mode() { stty -echo -icanon min 1 time 0 2>/dev/null; }
cleanup() { stty sane 2>/dev/null; restore_font; printf '\e[?1000l\e[?1006l\e[?25h\e[?1049l'; }
trap cleanup EXIT INT TERM
printf '\e[?1049h\e[?25l\e[?1000h\e[?1006h'; raw_mode   # alt screen, hide cursor, SGR mouse on
shrink_font; read_size; center_on_root

WINCH=0
trap 'WINCH=1' WINCH         # font change / window resize -> re-read size, redraw

# read a line of input at the bottom row (temporarily cooked + visible cursor)
prompt_line() {
  printf '\e[%d;1H\e[K\e[7m%s\e[0m\e[?25h' "$ROWS" "$1"
  stty icanon echo 2>/dev/null
  IFS= read -r REPLY_LINE 2>/dev/null </dev/tty || REPLY_LINE=""
  raw_mode; printf '\e[?25l'
}

status() {
  local z=${ZOOMS[ZI]} line crumb=""
  [ "$PANEL" = 1 ] && [ -n "$CRUMB" ] && crumb="  ${CRUMB}"
  line="$(basename "$FILE")  z:${z}x${crumb}${STATUSMSG:+  · ${STATUSMSG}}   [↵ open/drill · e all · Bksp back · t tree · tab focus · wheel/jk scroll · / find · q]"
  printf '\e[7m %-*.*s\e[0m' "$(( COLS - 1 ))" "$(( COLS - 1 ))" "$line"
}

draw() { derive_cam; printf '\e[H'; frame; printf '\n'; status; }

# vertical scroll: in the tree -> move cursor; in an entered (non-drilled) list ->
# move the SELECTED element and re-frame on it; otherwise free-pan the camera.
scroll_v() {
  [ -n "${CANVAS_DEBUG:-}" ] && echo "SCROLL $1 (ENTERED=$ENTERED DRILL=$DRILL SEL=$SEL)" >&2
  if [ "$TREEFOCUS" = 1 ]; then tree_move "$1"
  elif [ "$ENTERED" -ge 0 ] && [ "$DRILL" -lt 0 ]; then SEL=$(( SEL + $1 )); sel_recenter
  else CY=$(( CY + $1 * PANS[ZI] )); fi
}

# dispatch one key. Sets QUIT=1 to exit. Multi-byte sequences (arrows, SGR mouse)
# read their continuation here, so the main loop only ever hands us a first byte.
handle_key() {
  local key=$1 c1 c2 ch mb btn
  case "$key" in
    q|Q) QUIT=1 ;;
    t|T) PANEL=$(( 1 - PANEL )); STATUSMSG=$([ "$PANEL" = 1 ] && echo "tree panel on" || echo "tree panel off") ;;
    $'\t') if [ "$PANEL" = 1 ]; then TREEFOCUS=$(( 1 - TREEFOCUS ))
             [ "$TREEFOCUS" = 1 ] && CURREF=$(cur_centered_ref)   # start on what we're looking at
             STATUSMSG=$([ "$TREEFOCUS" = 1 ] && echo "tree focus — j/k walk · ↵ open · e expand" || echo "canvas focus"); fi ;;
    e|E) expand_all ;;                                          # open the whole visible structure
    h) CX=$(( CX - PANS[ZI] )) ;;
    l) CX=$(( CX + PANS[ZI] )) ;;
    k) scroll_v -1 ;;
    j) scroll_v 1 ;;
    +|=) [ "$ZI" -lt $(( ${#ZOOMS[@]} - 1 )) ] && ZI=$(( ZI + 1 )) ;;
    -|_) [ "$ZI" -gt 0 ] && ZI=$(( ZI - 1 )) ;;
    0) collapse_drill; ENTERED=-1; TREEFOCUS=0; STATUSMSG=""; fit_structure ;;
    f|F) if [ "$DRILL" -ge 0 ]; then model_bbox "$PREDRILL_M" "$M"; fit_view "$BBX0" "$BBY0" "$BBX1" "$BBY1"
         elif [ "$ENTERED" -ge 0 ]; then sel_recenter
         else fit_structure; fi
         STATUSMSG="fit to view" ;;
    $'\n'|$'\r')                                                # ↵ open list / drill element
      if [ "$TREEFOCUS" = 1 ]; then tree_enter
      elif [ "$ENTERED" -ge 0 ]; then drill_into "$ENTERED" "$SEL"
      else enter_huge; fi ;;
    $'\x7f'|$'\b')                                              # Backspace: close drill, then list
      if [ "$DRILL" -ge 0 ]; then collapse_drill; STATUSMSG="closed element"
      elif [ "$ENTERED" -ge 0 ]; then exit_list; STATUSMSG="back to structure"
      else STATUSMSG=""; fi ;;
    g) REPLY_LINE=""; prompt_line "goto (path e.g. records[23].child.child, or #): "
       if [ -z "$REPLY_LINE" ]; then :
       elif [[ "$REPLY_LINE" =~ ^[0-9]+$ ]] && [ "$ENTERED" -ge 0 ]; then
         collapse_drill; SEL=$REPLY_LINE; sel_recenter; STATUSMSG="element #$SEL selected — ↵ drill · e expand-all"
       else STATUSMSG="going to $REPLY_LINE…"; goto_path "$REPLY_LINE"; fi ;;
    /) REPLY_LINE=""; prompt_line "/"
       [ -n "$REPLY_LINE" ] && { STATUSMSG="searching…"; grep_find "$REPLY_LINE"; jump_to_match; } ;;
    n) MIDX=$(( MIDX + 1 )); jump_to_match ;;
    N) MIDX=$(( MIDX - 1 )); jump_to_match ;;
    i) STATUSMSG="indexing… (one-time)"; status; build_all_index; STATUSMSG="indexed" ;;
    $'\e')
      read -rsn1 -t 0.05 c1 || c1=""
      if [ "$c1" = "[" ] || [ "$c1" = "O" ]; then
        read -rsn1 -t 0.05 c2 || c2=""
        if [ "$c2" = "<" ]; then                                # SGR mouse: \e[<btn;x;y(M|m)
          mb=""; while read -rsn1 -t 0.05 ch; do case "$ch" in M|m) break ;; *) mb="$mb$ch" ;; esac; done
          btn=${mb%%;*}
          [ -n "${CANVAS_DEBUG:-}" ] && echo "MOUSE btn=$btn mb=$mb" >&2
          case "$btn" in 64) scroll_v -1 ;; 65) scroll_v 1 ;; esac
        elif [ "$c2" = "M" ]; then                              # legacy X10 mouse: 3 raw bytes
          read -rsn3 -t 0.05 ch; printf -v btn '%d' "'${ch:0:1}"
          case $(( btn - 32 )) in 64) scroll_v -1 ;; 65) scroll_v 1 ;; esac
        else
          case "$c2" in A) scroll_v -1 ;; B) scroll_v 1 ;; C) CX=$(( CX + PANS[ZI] )) ;; D) CX=$(( CX - PANS[ZI] )) ;; esac
        fi
      fi ;;
  esac
}

QUIT=0
while [ "$QUIT" = 0 ]; do
  [ "$WINCH" = 1 ] && { WINCH=0; read_size; }
  draw
  IFS= read -rsN1 key || { [ "$WINCH" = 1 ] && continue; break; }
  handle_key "$key"
  # coalesce a burst of buffered keystrokes into ONE redraw (kills the "down then
  # up takes seconds to catch up" lag: each key no longer forces a full frame).
  while [ "$QUIT" = 0 ] && IFS= read -rsN1 -t 0.002 key; do handle_key "$key"; done
done
